\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{rho-class/rhobabel}[15/04/2026 Rhobabel LaTeX2e package]

%----------------------------------------------------------
% Label for "keywords" 
%----------------------------------------------------------

\newcommand{\keywordname}{{\keywordheadfont{%
    \iflanguage{romanian}{Cuvinte cheie:\nobreakspace}{Keywords:\nobreakspace}%
}}}

\newcommand{\figlabel}{%
    \iflanguage{spanish}{{Fig.}}{\iflanguage{romanian}{{Fig.}}{{Fig.}}}%
}

\newcommand{\figslabel}{%
    \iflanguage{spanish}{{Figs.}}{\iflanguage{romanian}{{Figs.}}{{Figs.}}}%
}

\newcommand{\tablabel}{%
    \iflanguage{spanish}{{Tabla}}{\iflanguage{romanian}{{Tabel}}{{Table}}}%
}

\newcommand{\captionlabelcode}{%
    \iflanguage{spanish}{{C\'odigo}}{\iflanguage{romanian}{{Cod}}{{Code}}}%
}

\newcommand{\eqlabel}{%
    \iflanguage{spanish}{{Ecuaci\'on}}{\iflanguage{romanian}{{Ecua\c{t}ie}}{{Equation}}}%
}

\newcommand{\andlanguage}{%
    \iflanguage{spanish}{{ y }}{\iflanguage{romanian}{{ \c{s}i }}{{ and }}}%
}

\newcommand{\infolanguage}{%
    \iflanguage{spanish}{{Informaci\'on}}{\iflanguage{romanian}{{Informa\c{t}ie}}{{Information}}}%
}

\newcommand{\notelanguage}{%
    \iflanguage{spanish}{{Nota}}{\iflanguage{romanian}{{Not\u{a}}}{{Note}}}%
}

